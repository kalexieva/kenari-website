---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="Contact Us | Kenari"
  description="Contact us for more information about our dance group"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Contact Us"
        tagline="Have a question or want to join us? Send us a message!"
      />

      <div class="content">
        <form action="https://api.web3forms.com/submit" method="POST">
          <input
            type="hidden"
            name="access_key"
            value="f8cee8db-3625-499a-b562-4d9ddb50f534"
          />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            style="display: none;"
          />
          <input type="hidden" name="from_name" value="Kenari Website Form" />

          <div class="field">
            <input type="text" id="name" name="name" required placeholder=" " />
            <label for="name">Name</label>
            <span class="error-message" id="name-error"
              >Please enter your name.</span
            >
          </div>

          <div class="field">
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder=" "
            />
            <label for="email">Email</label>
            <span class="error-message" id="email-error"
              >Please enter a valid email address.</span
            >
          </div>

          <div class="field">
            <textarea id="message" name="message" required placeholder=" "
            ></textarea>
            <label for="message">Message</label>
            <span class="error-message" id="message-error"
              >Please enter a message.</span
            >
          </div>

          <button type="submit">
            Submit Form
            <Icon icon="paper-plane-tilt" size="1.2em" />
          </button>
        </form>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const form = document.querySelector("form");
  const inputs = form?.querySelectorAll("input, textarea");

  form?.addEventListener("submit", (event) => {
    if (!form.checkValidity()) {
      event.preventDefault();
      inputs?.forEach((input) => {
        const htmlInput = input as HTMLInputElement | HTMLTextAreaElement;
        // Add a class to force validation styles even if not yet "touched"
        htmlInput.classList.add("submitted");
      });
    }
  });

  inputs?.forEach((input) => {
    input.addEventListener("blur", () => {
      (input as HTMLElement).classList.add("touched");
    });
  });
</script>

<style>
  .content {
    max-width: 50rem;
    margin-inline: auto;
    width: 100%;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem;
    background-color: var(--gray-999_40);
    border: 1px solid var(--gray-800);
    border-radius: 0.75rem;
    box-shadow: var(--shadow-md);
  }

  .field {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
  }

  label {
    position: absolute;
    left: 1rem;
    top: 1rem;
    font-weight: 600;
    color: var(--gray-200);
    pointer-events: none;
    transition:
      transform var(--theme-transition),
      font-size var(--theme-transition),
      color var(--theme-transition);
    transform-origin: left top;
  }

  input,
  textarea {
    width: 100%;
    padding: 1.5rem 1rem 0.5rem;
    border: 1px solid var(--gray-800);
    border-radius: 0.5rem;
    background-color: var(--gray-999);
    color: var(--gray-100);
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: border-color var(--theme-transition);
  }

  input:focus ~ label,
  input:not(:placeholder-shown) ~ label,
  textarea:focus ~ label,
  textarea:not(:placeholder-shown) ~ label {
    transform: translateY(-0.75rem) scale(0.8);
  }

  input:focus,
  textarea:focus {
    outline: none;
  }

  /* Validation Styles */
  input.touched:invalid,
  textarea.touched:invalid,
  input.submitted:invalid,
  textarea.submitted:invalid {
    border-color: #cc0000;
  }

  input.touched:invalid ~ label,
  textarea.touched:invalid ~ label,
  input.submitted:invalid ~ label,
  textarea.submitted:invalid ~ label {
    color: #cc0000;
  }

  .error-message {
    font-size: var(--text-sm);
    color: #cc0000;
    display: none;
  }

  input.touched:invalid ~ .error-message,
  textarea.touched:invalid ~ .error-message,
  input.submitted:invalid ~ .error-message,
  textarea.submitted:invalid ~ .error-message {
    display: block;
  }

  textarea {
    min-height: 10rem;
    resize: vertical;
  }

  button {
    position: relative;
    display: flex;
    place-content: center;
    text-align: center;
    padding: 0.56em 2em;
    gap: 0.8em;
    color: var(--accent-text-over);
    text-decoration: none;
    line-height: 1.1;
    border-radius: 999rem;
    overflow: hidden;
    background: var(--gradient-accent-orange);
    box-shadow: var(--shadow-sm);
    white-space: nowrap;
    margin-inline: auto;
    border: 0;
    cursor: pointer;
    font: inherit;
    appearance: none;
    -webkit-appearance: none;
  }

  button:hover,
  button:focus {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.1)),
      var(--gradient-accent-orange);
  }

  @media (min-width: 50em) {
    .hero {
      padding-bottom: 4rem;
    }

    .hero h1 {
      font-size: var(--text-5xl);
    }

    .hero p {
      font-size: var(--text-xl);
    }

    form {
      padding: 4rem;
      margin-top: 4rem;
      margin-bottom: 2rem;
    }

    button {
      font-size: var(--text-xl);
    }
  }
</style>
