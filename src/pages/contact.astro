---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout title="Contact Us | Kenari" description="Contact us for more information about our dance group">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Contact Us"
				tagline="Have a question or want to join us? Send us a message!"
			/>

			<div class="content">
				<form action="https://api.web3forms.com/submit" method="POST">
					<input type="hidden" name="access_key" value="f8cee8db-3625-499a-b562-4d9ddb50f534">
                    <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
                    <input type="hidden" name="from_name" value="Kenari Website Form">
					
					<div class="field">
						<input type="text" id="name" name="name" required placeholder=" ">
						<label for="name">Name</label>
					</div>

					<div class="field">
						<input type="email" id="email" name="email" required placeholder=" ">
						<label for="email">Email</label>
					</div>

					<div class="field">
						<textarea id="message" name="message" required placeholder=" "></textarea>
						<label for="message">Message</label>
					</div>

					<button type="submit">
						Submit Form
						<Icon icon="paper-plane-tilt" size="1.2em" />
					</button>
				</form>
			</div>
		</main>
	</div>
</BaseLayout>

<style>
	.hero {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
		text-align: center;
	}

	.hero h1 {
		font-size: var(--text-3xl);
		color: var(--gray-0);
	}

	.hero p {
		font-size: var(--text-md);
		color: var(--gray-400);
	}

	.content {
		max-width: 50rem;
		margin-inline: auto;
		width: 100%;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: 2.5rem;
		background-color: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		box-shadow: var(--shadow-sm);
	}

	.field {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		align-items: flex-start;
	}

	label {
		position: absolute;
		left: 1rem;
		top: 0.75rem;
		font-weight: 600;
		color: var(--gray-400);
		pointer-events: none;
		transition: transform var(--theme-transition), font-size var(--theme-transition), color var(--theme-transition);
		transform-origin: left top;
	}

	input,
	textarea {
		width: 100%;
		padding: 1.5rem 1rem 0.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		background-color: var(--gray-999);
		color: var(--gray-200);
		font-family: var(--font-body);
		font-size: var(--text-base);
		transition: border-color var(--theme-transition);
	}

	input:focus ~ label,
	input:not(:placeholder-shown) ~ label,
	textarea:focus ~ label,
	textarea:not(:placeholder-shown) ~ label {
		transform: translateY(-0.75rem) scale(0.8);
		color: var(--accent-regular);
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--accent-regular);
	}

	textarea {
		min-height: 10rem;
		resize: vertical;
	}

	button {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.8rem;
		padding: 0.75rem 2.5rem;
		color: var(--accent-text-over);
		font-size: var(--text-lg);
		font-weight: 600;
		text-decoration: none;
		line-height: 1.1;
		border-radius: 999rem;
		border: 0;
		background: var(--gradient-accent-orange);
		box-shadow: var(--shadow-md);
		white-space: nowrap;
		cursor: pointer;
		transition: background-color var(--theme-transition);
		align-self: flex-start;
	}

	button:hover,
	button:focus {
		background-image: linear-gradient(rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.1)), var(--gradient-accent-orange);
	}

	@media (min-width: 50em) {
		.hero {
			padding-bottom: 4rem;
		}

		.hero h1 {
			font-size: var(--text-5xl);
		}

		.hero p {
			font-size: var(--text-xl);
		}

		form {
			padding: 4rem;
		}

		button {
			font-size: var(--text-xl);
			padding: 1.125rem 2.5rem;
		}
	}
</style>
