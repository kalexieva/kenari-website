---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import pswpInitUrl from "../scripts/PhotoSwipeInitialization.ts?url";

interface Props {
    images: ImageMetadata[];
    /** Used for accessible labels and to help generate a stable gallery id */
    title: string;
    /** Optional stable id (recommended: use the event slug) */
    id?: string;
    /** Thumbnail width in pixels (default: 720) */
    thumbWidth?: number;
}

const {
    images,
    title,
    id,
    thumbWidth = 720,
} = Astro.props;

const galleryId =
    id ? `pswp-${id}` : `pswp-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
---

<div class="pswp-gallery gallery-grid" id={galleryId} data-pswp-gallery>
    {
        images.map((img) => (
                <a
                        href={img.src}
                        data-pswp-width={img.width}
                        data-pswp-height={img.height}
                        aria-label={`Open photo from ${title}`}
                >
                    <Image
                            src={img}
                            width={thumbWidth}
                            sizes="(min-width: 50em) 50vw, 100vw"
                            alt={`Photo from ${title}`}
                            loading="lazy"
                            decoding="async"
                            class="thumb"
                    />
                </a>
        ))
    }
</div>

<script type="module" src={pswpInitUrl}></script>

<style>
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1rem;
        align-items: stretch;
    }

    .gallery-grid a {
        display: block;
        text-decoration: none;
    }

    .thumb {
        width: 100%;
        aspect-ratio: 4 / 3;
        height: auto;
        object-fit: cover;
        border-radius: 1rem;
        border: 1px solid var(--gray-800);
        box-shadow: var(--shadow-sm);
        background: var(--gradient-subtle);
    }

    @media (min-width: 50em) {
        .gallery-grid {
            grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
            gap: 1.5rem;
        }

        .thumb {
            border-radius: 1rem;
        }
    }
</style>
