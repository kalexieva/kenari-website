---
import CallToAction from "./CallToAction.astro";
import Icon from "./Icon.astro";
type CalendarEvent = {
    title: string;
    start?: string;
    allDay?: boolean;
    excludeFromUpcoming?: boolean;
    location: Location;
};

type Location = {
    name: string;
    address: string;
    url: string;
}

// Fetch the same JSON that the calendar uses (keeps one source of truth)
const res = await fetch(new URL("/events.json", Astro.url));
const data = (await res.json()) as { events: CalendarEvent[] };

const now = new Date();

const upcoming = (data.events ?? [])
    // Don't show events where excludeFromUpcoming = true
    .filter((e) => !e.excludeFromUpcoming)
    // Only show events that have a `start` date
    .filter((e) => typeof e.start === "string" && e.start.length > 0)
    .map((e) => ({ ...e, startDate: new Date(e.start!) }))
    .filter((e) => !Number.isNaN(e.startDate.getTime()))
    // Only show events where start date >= now
    .filter((e) => e.startDate >= now)
    .sort((a, b) => a.startDate.getTime() - b.startDate.getTime())
    // Only show the next 5 events
    .slice(0, 5);

function formatEventDate(event: { startDate: Date; allDay?: boolean }) {
    const datePart = new Intl.DateTimeFormat("en-US", {
        dateStyle: "full",
        timeZone: "America/Phoenix",
    }).format(event.startDate);

    if (event.allDay) return datePart;

    const timePart = new Intl.DateTimeFormat("en-US", {
        hour: "numeric",
        minute: "2-digit",
    }).format(event.startDate);

    return `${datePart} • ${timePart}`;
}
---

<section class="outline">
    <div class="stack gap-8">
        <h2>Upcoming Events</h2>

        {upcoming.length > 0 ? (
                <ul class="events-list gap-4" aria-label="Upcoming events">
                    {upcoming.map((event) => (
                            <li class="event-item">
                                <div><h5>{event.title}</h5></div>
                                <div>{formatEventDate(event)}</div>
                                <div>{event.location.name}</div>
                                <div>
                                    <a href={event.location.url} target="_blank" rel="noopener noreferrer">{event.location.address}</a>
                                </div>
                            </li>
                    ))}
                </ul>
        ) : (
                <p class="empty">No upcoming events posted yet. Check the full calendar.</p>
        )}

        <div class="calendar-button">
            <CallToAction href="/calendar">
                View Full Calendar
                <Icon icon="arrow-right" size="1.2em" />
            </CallToAction>
        </div>
    </div>
</section>

<style>
    .outline {
        border-bottom: 1px solid var(--gray-800);
        padding-bottom: 5rem;
        background-color: var(--gray-999_40);
        box-shadow: var(--shadow-sm);
        text-align: center;
    }

    .events-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        margin-inline: auto;
    }

    .event-item {
        padding: 1rem 1.25rem;
        border: 1px solid var(--gray-800);
        border-radius: 0.75rem;
        background: var(--gray-900);
        text-align: left;
    }

    .empty {
        color: var(--gray-300);
    }

    .calendar-button {
        margin-inline: auto;
    }
</style>