---
import CallToAction from "./CallToAction.astro";
import Icon from "./Icon.astro";
import eventsData from "../data/events.json";

type CalendarEvent = {
    title: string;
    start?: string;
    allDay?: boolean;
    excludeFromUpcoming?: boolean;
    location: Location;
};

type Location = {
    name: string;
    address: string;
    url: string;
}

const data = eventsData as { events: CalendarEvent[] };

const now = new Date();

const upcoming = (data.events ?? [])
    // Don't show events where excludeFromUpcoming = true
    .filter((e) => !e.excludeFromUpcoming)
    // Only show events that have a `start` date
    .filter((e) => typeof e.start === "string" && e.start.length > 0)
    .map((e) => ({ ...e, startDate: new Date(e.start!) }))
    .filter((e) => !Number.isNaN(e.startDate.getTime()))
    // Only show events where start date >= now
    .filter((e) => e.startDate >= now)
    .sort((a, b) => a.startDate.getTime() - b.startDate.getTime())
    // Only show the next 5 events
    .slice(0, 5);

function formatEventDate(event: { startDate: Date; allDay?: boolean }) {
    const datePart = new Intl.DateTimeFormat("en-US", {
        dateStyle: "medium",
        timeZone: "America/Phoenix",
    }).format(event.startDate);

    if (event.allDay) return datePart;

    const timePart = new Intl.DateTimeFormat("en-US", {
        timeStyle: "short"
    }).format(event.startDate);

    return `${datePart} • ${timePart}`;
}
---

<section class="outline">
    <div class="stack gap-8">
        <h2>Upcoming Events</h2>

        {upcoming.length > 0 ? (
                <ul class="events-list gap-4" aria-label="Upcoming events">
                    {upcoming.map((event) => (
                            <li class="event-item">
                                <p class="event-text"><strong>{formatEventDate(event)}</strong></p>
                                <p class="event-text">{event.title}</p>
                                <div>
                                    <p><strong>{event.location.name}</strong></p>
                                    <p><a href={event.location.url} target="_blank" rel="noopener noreferrer">{event.location.address}</a></p>
                                </div>
                            </li>
                    ))}
                </ul>
        ) : (
                <p class="empty">No upcoming events posted yet. Check the calendar for all events.</p>
        )}

        <div class="calendar-button">
            <CallToAction href="/calendar">
                View Calendar
                <Icon icon="calendar-dots" size="1.2em" />
            </CallToAction>
        </div>
    </div>
</section>

<style>
    .outline {
        border-bottom: 1px solid var(--gray-800);
        padding-bottom: 5rem;
        background-color: var(--gray-999_40);
        box-shadow: var(--shadow-sm);
        text-align: center;
    }

    .events-list {
        list-style: none;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
        display: grid;
        margin-inline: auto;
    }

    .event-item {
        padding: 1rem 1.25rem;
        border: 1px solid var(--gray-800);
        border-radius: 0.75rem;
        background: var(--gray-900);
        text-align: left;
    }

    .event-text {
        font-size: var(--text-md);
        margin-bottom: 0.5rem;
    }

    .empty {
        color: var(--gray-300);
    }

    .calendar-button {
        margin-inline: auto;
    }

    @media (min-width: 50em) {
        .events-list {
            padding-left: 0;
            padding-right: 0;
            max-width: 50rem;
        }

        .event-item {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 2rem;
        }

        .event-text {
            font-size: var(--text-lg);
            align-self: center;
            justify-self: start;
            margin-bottom: 0;
        }
    }
</style>